# Copy to .env or .env.local and fill in real values.
# Place ID:  https://developers.google.com/maps/documentation/places/web-service/place-id
#
# API key (server-side only - used by /api/google-reviews, never sent to the browser):
#   1. Enable "Places API" (legacy) in Google Cloud Console.
#   2. Create a separate key for the server route - do NOT use HTTP referrer restriction
#      (referer-restricted keys fail with "cannot be used with this API").
#   3. Use "IP addresses" restriction for production, or "None" while testing locally.
#   4. Restart `npm run dev` after changing env vars.

GOOGLE_PLACE_ID=
GOOGLE_MAPS_API_KEY=
